# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://sguser:sgpassword@localhost:5432/sgjobfinder"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Job Source ────────────────────────────────────────────────────────────────
JOB_JSON_URL="https://raw.githubusercontent.com/eaziym/sg-jobs/refs/heads/main/docs/data/jobs.min.json"
# Optional: Bearer token if the API requires auth
# JOB_API_TOKEN=""

# ─── Auth Providers (OAuth) ───────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (Magic Link) ───────────────────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="noreply@sg-job-finder.app"

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses
ADMIN_EMAILS="admin@yourdomain.com"

# ─── Dev Seeds ─────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@yourdomain.com"

# ─── Security ──────────────────────────────────────────────────────────────────
# Set to true in production to disable /api/ingest/preview endpoint
DISABLE_INGEST_PREVIEW="false"

# ─── Docker ────────────────────────────────────────────────────────────────────
POSTGRES_USER="sguser"
POSTGRES_PASSWORD="sgpassword"
POSTGRES_DB="sgjobfinder"
